{
  "name": "aerodesign-command-center",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @aerodesign/web dev",
    "dev:api": "pnpm --filter @aerodesign/api dev",
    "build": "pnpm --filter @aerodesign/shared build && pnpm --filter @aerodesign/api build && pnpm --filter @aerodesign/web build",
    "lint": "pnpm --filter @aerodesign/web lint && pnpm --filter @aerodesign/api lint"
  }
}
